# 示例配置
# 复制此文件为 .env 并填入你的 API 密钥

# AI 名称
ASSISTANT_NAME=Domiclaw

# 模型配置
# 选择一个你需要的模型，填入对应配置

# DeepSeek V4（推荐）
# MODEL_NAME=deepseek-v4-flash
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_API_KEY=your-deepseek-api-key
# THINKING_MODE=thinking    # thinking (default) | thinking_max

# DeepSeek V3 / legacy
# MODEL_NAME=deepseek-chat
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_API_KEY=your-deepseek-api-key

# Qwen
# MODEL_NAME=qwen-turbo
# MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_API_KEY=your-qwen-api-key

# Anthropic
# MODEL_NAME=claude-sonnet-4-20250514
# MODEL_BASE_URL=https://api.anthropic.com
# MODEL_API_KEY=sk-ant-your-api-key

# Web channel (optional — set a port to enable the browser UI)
# WEBCLIENT_PORT=3456